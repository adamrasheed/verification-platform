{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verification-platform.invalid/schemas/events/event-envelope.schema.json",
  "title": "EventEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "eventType",
    "occurredAt",
    "invocationId",
    "correlationId",
    "sequence",
    "producer",
    "dataClassification",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "eventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "eventType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "invocationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "subject": {
      "$ref": "#/$defs/revisionRef"
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "producer": {
      "$ref": "#/$defs/producerRef"
    },
    "dataClassification": {
      "enum": [
        "SECRET",
        "LOCAL_SOURCE",
        "SENSITIVE_EVIDENCE",
        "MINIMAL_METADATA",
        "EXPLICIT_SHARE"
      ]
    },
    "payload": {
      "type": [
        "null",
        "boolean",
        "number",
        "string",
        "array",
        "object"
      ]
    }
  },
  "$defs": {
    "producerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "artifactDigest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "artifactDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "revisionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "revision",
        "schemaVersion"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "revision": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "schemaVersion": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
