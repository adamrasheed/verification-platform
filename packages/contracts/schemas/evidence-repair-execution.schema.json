{
  "$id": "urn:verify:schema:contracts:evidence-repair-execution:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence, Repair, Execution Plan and Manifest Contracts",
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "opaqueId": {"type": "string", "minLength": 1, "maxLength": 512},
    "revisionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "revision", "schemaVersion"],
      "properties": {
        "kind": {"type": "string", "not": {"enum": ["latest", "current", "alias"]}},
        "id": {"$ref": "#/$defs/opaqueId"},
        "revision": {"$ref": "#/$defs/digest"},
        "schemaVersion": {"type": "integer", "minimum": 1}
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "artifactDigest"],
      "properties": {
        "id": {"$ref": "#/$defs/opaqueId"},
        "version": {"type": "string", "minLength": 1},
        "artifactDigest": {"$ref": "#/$defs/digest"}
      }
    },
    "attemptRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attemptId", "proof", "invocationId"],
      "properties": {
        "attemptId": {"$ref": "#/$defs/opaqueId"},
        "proof": {"$ref": "#/$defs/revisionRef"},
        "invocationId": {"$ref": "#/$defs/opaqueId"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "revision", "schemaVersion", "evidenceType", "mediaType",
        "producer", "captureMethod", "capturedAt", "attempt", "subjects",
        "inputRefs", "contentDigest", "byteSize", "classification",
        "chainOfCustody", "supersedes"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/opaqueId"},
        "revision": {"$ref": "#/$defs/digest"},
        "schemaVersion": {"type": "integer", "minimum": 1},
        "evidenceType": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 1},
        "producer": {"$ref": "#/$defs/producer"},
        "captureMethod": {"type": "string", "minLength": 1},
        "capturedAt": {"type": "string", "format": "date-time", "pattern": "Z$"},
        "attempt": {"$ref": "#/$defs/attemptRef"},
        "subjects": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/revisionRef"}},
        "inputRefs": {"type": "array", "items": {"$ref": "#/$defs/revisionRef"}},
        "contentDigest": {"$ref": "#/$defs/digest"},
        "byteSize": {"type": "integer", "minimum": 0},
        "classification": {
          "enum": ["SECRET", "LOCAL_SOURCE", "SENSITIVE_EVIDENCE", "MINIMAL_METADATA", "EXPLICIT_SHARE"]
        },
        "chainOfCustody": {"type": "array", "minItems": 1},
        "supersedes": {"type": "array", "items": {"$ref": "#/$defs/revisionRef"}}
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "revision", "schemaVersion", "motivatingPromise",
        "motivatingExecution", "evidence", "generator", "action", "assumptions",
        "requiredPermissions", "expectedEffect", "confidence", "verificationPlan"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/opaqueId"},
        "revision": {"$ref": "#/$defs/digest"},
        "schemaVersion": {"type": "integer", "minimum": 1},
        "motivatingPromise": {"$ref": "#/$defs/revisionRef"},
        "motivatingExecution": {"$ref": "#/$defs/attemptRef"},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/revisionRef"}},
        "generator": {"$ref": "#/$defs/producer"},
        "action": {
          "type": "object",
          "oneOf": [
            {
              "additionalProperties": false,
              "required": ["kind", "target", "expectedContentDigest", "operations"],
              "properties": {
                "kind": {"const": "jsonPatch"},
                "target": {
                  "type": "string",
                  "pattern": "^(?:\\.|(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//).+)$"
                },
                "expectedContentDigest": {"$ref": "#/$defs/digest"},
                "operations": {"type": "array", "minItems": 1}
              }
            },
            {
              "additionalProperties": false,
              "required": ["kind", "instructionCode", "parameters"],
              "properties": {
                "kind": {"const": "advisoryInstruction"},
                "instructionCode": {"type": "string", "minLength": 1},
                "parameters": {"type": ["array", "boolean", "null", "number", "object", "string"]}
              }
            }
          ]
        },
        "assumptions": {"type": "array", "items": {"type": "string"}},
        "requiredPermissions": {"type": "object"},
        "expectedEffect": {"type": "string", "minLength": 1},
        "confidence": {"type": "object"},
        "verificationPlan": {"$ref": "#/$defs/revisionRef"},
        "llmGeneration": {"type": "object"}
      }
    },
    "executionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "revision", "schemaVersion", "applicationModel",
        "executionContext", "proofs", "discoveryOutputDigest"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/opaqueId"},
        "revision": {"$ref": "#/$defs/digest"},
        "schemaVersion": {"type": "integer", "minimum": 1},
        "applicationModel": {"$ref": "#/$defs/revisionRef"},
        "executionContext": {"$ref": "#/$defs/revisionRef"},
        "proofs": {"type": "array"},
        "policyRevision": {"$ref": "#/$defs/revisionRef"},
        "configurationRevision": {"$ref": "#/$defs/revisionRef"},
        "discoveryOutputDigest": {"$ref": "#/$defs/digest"}
      }
    },
    "executionManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "revision", "schemaVersion", "engine", "applicationModel",
        "promises", "proof", "pluginsAndTools", "source", "configurationDigest",
        "policyDigest", "platform", "authenticationBindingIds", "isolation",
        "discoveryOutputDigest", "executionPlan", "executionPlanDigest"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/opaqueId"},
        "revision": {"$ref": "#/$defs/digest"},
        "schemaVersion": {"type": "integer", "minimum": 1},
        "engine": {"$ref": "#/$defs/producer"},
        "applicationModel": {"$ref": "#/$defs/revisionRef"},
        "promises": {"type": "array", "items": {"$ref": "#/$defs/revisionRef"}},
        "proof": {"$ref": "#/$defs/revisionRef"},
        "pluginsAndTools": {"type": "array"},
        "source": {"type": "object"},
        "configurationDigest": {"$ref": "#/$defs/digest"},
        "policyDigest": {"$ref": "#/$defs/digest"},
        "platform": {"type": "object"},
        "authenticationBindingIds": {
          "type": "array",
          "items": {"$ref": "#/$defs/opaqueId"}
        },
        "isolation": {"type": "object"},
        "discoveryOutputDigest": {"$ref": "#/$defs/digest"},
        "executionPlan": {"$ref": "#/$defs/revisionRef"},
        "executionPlanDigest": {"$ref": "#/$defs/digest"}
      }
    }
  }
}
