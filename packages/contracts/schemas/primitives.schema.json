{
  "$id": "urn:verify:schema:contracts:primitives:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verification Contract Primitives",
  "$defs": {
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "rfc3339Utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "byteCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "dataClassification": {
      "enum": [
        "SECRET",
        "LOCAL_SOURCE",
        "SENSITIVE_EVIDENCE",
        "MINIMAL_METADATA",
        "EXPLICIT_SHARE"
      ]
    }
  }
}
