{
  "$id": "urn:verify:schema:plugin-contract:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verification Provider Plugin Contract",
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$"
    },
    "contractVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor"],
      "properties": {
        "major": {"type": "integer", "minimum": 1},
        "minor": {"type": "integer", "minimum": 0}
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scheme",
        "host",
        "port",
        "pathTemplateIds",
        "methods",
        "outboundSchemaIds",
        "outboundClassifications",
        "maximumRequestBytes",
        "maximumResponseBytes"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "scheme": {"const": "https"},
        "host": {"type": "string", "minLength": 1, "maxLength": 253},
        "port": {"const": 443},
        "pathTemplateIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["GET", "POST"]}
        },
        "outboundSchemaIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "outboundClassifications": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["MINIMAL_METADATA", "EXPLICIT_SHARE"]}
        },
        "maximumRequestBytes": {"type": "integer", "minimum": 0, "maximum": 1048576},
        "maximumResponseBytes": {"type": "integer", "minimum": 1, "maximum": 8388608},
        "secretAudience": {"type": "string", "minLength": 1},
        "secretScopes": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "dependentRequired": {
        "secretAudience": ["secretScopes"],
        "secretScopes": ["secretAudience"]
      }
    },
    "providerRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerRequestId",
        "destinationId",
        "method",
        "pathTemplateId",
        "pathParameters",
        "outboundSchemaId",
        "classification",
        "body"
      ],
      "properties": {
        "providerRequestId": {"type": "string", "minLength": 1, "maxLength": 512},
        "destinationId": {"$ref": "#/$defs/identifier"},
        "method": {"enum": ["GET", "POST"]},
        "pathTemplateId": {"$ref": "#/$defs/identifier"},
        "pathParameters": {},
        "outboundSchemaId": {"type": "string", "minLength": 1},
        "classification": {"enum": ["MINIMAL_METADATA", "EXPLICIT_SHARE"]},
        "body": {},
        "secretReferenceId": {"type": "string", "minLength": 1}
      }
    },
    "operationalError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "retryability", "message"],
      "properties": {
        "code": {
          "enum": [
            "VFY_PROVIDER_AUTHENTICATION_FAILED",
            "VFY_PROVIDER_NOT_FOUND",
            "VFY_PROVIDER_PERMISSION_DENIED",
            "VFY_PROVIDER_RATE_LIMITED",
            "VFY_PROVIDER_UNAVAILABLE"
          ]
        },
        "retryability": {"enum": ["never", "safe", "policy_required"]},
        "message": {"type": "string", "minLength": 1, "maxLength": 256}
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "namespace",
        "pluginId",
        "implementationVersion",
        "artifactDigest",
        "contractVersions",
        "compatibleEngine",
        "entryPoint",
        "platforms",
        "capabilities",
        "operations",
        "evidenceTypes",
        "requiredInputs",
        "permissions",
        "sideEffects",
        "publisher",
        "signature"
      ],
      "properties": {
        "schemaVersion": {"const": 1},
        "namespace": {"$ref": "#/$defs/identifier"},
        "pluginId": {"$ref": "#/$defs/identifier"},
        "implementationVersion": {
          "type": "string",
          "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
        },
        "artifactDigest": {"$ref": "#/$defs/digest"},
        "contractVersions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {"$ref": "#/$defs/contractVersion"}
        },
        "compatibleEngine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximumExclusive"],
          "properties": {
            "minimum": {"type": "string"},
            "maximumExclusive": {"type": "string"}
          }
        },
        "entryPoint": {"type": "string", "minLength": 1, "maxLength": 512},
        "platforms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["os", "architecture"],
            "properties": {
              "os": {"enum": ["darwin", "linux", "win32"]},
              "architecture": {"type": "string", "minLength": 1}
            }
          }
        },
        "capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "discover",
              "describeProofs",
              "captureEvidence",
              "suggestRepairs",
              "observeProvider"
            ]
          }
        },
        "evidenceTypes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "requiredInputs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "filesystemReadRoots",
            "filesystemWriteRoots",
            "subprocess",
            "destinations",
            "secrets"
          ],
          "properties": {
            "filesystemReadRoots": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
            "filesystemWriteRoots": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
            "subprocess": {"type": "boolean"},
            "destinations": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/destination"}},
            "secrets": {
              "type": "array",
              "maxItems": 32,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["audience", "scopes"],
                "properties": {
                  "audience": {"type": "string", "minLength": 1},
                  "scopes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
                }
              }
            }
          }
        },
        "sideEffects": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "publisher": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "keyId", "sourceRevision", "buildUrl"],
          "properties": {
            "id": {"$ref": "#/$defs/identifier"},
            "keyId": {"type": "string", "minLength": 1},
            "sourceRevision": {"type": "string", "minLength": 1},
            "buildUrl": {"type": "string", "pattern": "^https://"}
          }
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "keyId", "value"],
          "properties": {
            "algorithm": {"const": "Ed25519"},
            "keyId": {"type": "string", "minLength": 1},
            "value": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "messageType", "requestId", "payload"],
      "properties": {
        "protocolVersion": {"type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+$"},
        "messageType": {
          "enum": [
            "handshake.request",
            "handshake.response",
            "operation.request",
            "contribution",
            "provider.request",
            "provider.response",
            "cancel.request",
            "complete",
            "error"
          ]
        },
        "requestId": {"type": "string", "minLength": 1, "maxLength": 512},
        "payload": {}
      }
    }
  },
  "oneOf": [
    {"$ref": "#/$defs/manifest"},
    {"$ref": "#/$defs/message"},
    {"$ref": "#/$defs/providerRequest"},
    {"$ref": "#/$defs/operationalError"}
  ]
}
