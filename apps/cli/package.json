{
  "name": "@adamrasheed/verify",
  "version": "0.2.0",
  "description": "Offline, evidence-backed JavaScript workspace integrity verification",
  "license": "Apache-2.0",
  "homepage": "https://github.com/adamrasheed/verification-platform#readme",
  "bugs": {
    "url": "https://github.com/adamrasheed/verification-platform/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamrasheed/verification-platform.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "bin": {
    "verify": "./dist/verify.js"
  },
  "files": [
    "dist/verify.js",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@verify-internal/adapter-core": "0.0.0",
    "@verify-internal/engine": "0.0.0",
    "@verify-internal/protocol": "0.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json && esbuild dist/bin/verify.js --bundle --platform=node --format=esm --target=node22 --legal-comments=none --outfile=dist/verify.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  }
}
